# =================================================================
# ⚡ LIMITLESS BOT SECRETS CONFIGURATION ⚡
# =================================================================

# 🔑 NATIVE WHATSAPP AUTHENTICATION
# Paste your generated base64 Session ID (starting with Limitless~...) here.
# Leave empty if you are linking via pairing code for the first time.
SESSION_ID=Limitless~YourBase64SessionIDBytesHere

# 👑 PRIMARY BOT OWNER
# Your WhatsApp phone number with country code (digits only, no '+' sign).
OWNER_NUMBER=601129363700

# 🤖 AI ENGINE CREDENTIALS
# Your Google Gemini API Key.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 🌐 PAIRING HUB NETWORK PORT
# The network port your browser-based pairing site (server.js) will listen on.
# Default is 3000.
PORT=3000